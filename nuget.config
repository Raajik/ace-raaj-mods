<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Existing local/offline sources; adjust if you use different ones -->
    <add key="VSOffline" value="C:\Program Files (x86)\Microsoft SDKs\NuGetPackages\" />

    <!-- Allow NuGet.org, but lock it down via mapping below -->
    <add key="NuGet.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <packageSourceMapping>
    <!-- VSOffline: fallback for anything not explicitly mapped to NuGet.org -->
    <packageSource key="VSOffline">
      <package pattern="*" />
    </packageSource>

    <!-- NuGet.org is only used for explicitly listed packages -->
    <packageSource key="NuGet.org">
      <package pattern="SixLabors.ImageSharp" />
      <package pattern="ExcelMapper" />
      <package pattern="ACEmulator.ACE.Shared" />
      <package pattern="ACRealms.ACE.Shared" />
      <package pattern="Lib.Harmony" />
      <package pattern="Krafs.Publicizer" />
      <package pattern="AngouriMath" />
      <package pattern="Honk*" />
      <package pattern="System.Drawing.Common" />
    </packageSource>
  </packageSourceMapping>
</configuration>

